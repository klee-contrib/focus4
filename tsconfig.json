{
    "compilerOptions": {
        // Général
        "lib": ["es2023", "dom"],
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "target": "es2023",
        "sourceMap": true,

        // Options additionnelles
        "importHelpers": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedSideEffectImports": false,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "skipLibCheck": true,

        // Spécifique librairie
        "declaration": true,
        "declarationMap": true,
        "inlineSources": true,
        "stripInternal": true,
        "noEmitOnError": true
    },
    "include": ["packages"],
    "exclude": ["**/lib/**"]
}
